{
  "name": "claude-time-slot-widget",
  "version": "0.1.0",
  "description": "Windows widget for Claude peak/off-peak time slots and live usage",
  "main": "main.js",
  "license": "MIT",
  "author": "Codex",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --debug",
    "build": "electron-builder --win",
    "build:win": "electron-builder --win portable nsis",
    "test": "node --test tests/*.test.js"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.codex.claude-time-slot-widget",
    "productName": "Claude Time-Slot Widget",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable",
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${target}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-setup.${ext}"
    }
  }
}
